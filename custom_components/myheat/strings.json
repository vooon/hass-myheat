  "options": {
    "step": {
      "local_init": {
        "title": "Local API",
        "description": "Optional LAN API access. The device LAN address should be trusted because local access can control heating.",
        "data": {
          "local_mode_enabled": "Enable local API",
          "local_host": "Host",
          "local_protocol": "Protocol",
          "local_username": "[%key:common::config_flow::data::username%]",
          "local_password": "[%key:common::config_flow::data::password%]",
          "local_request_timeout": "Request timeout",
          "local_poll_interval": "Local poll interval"
        }
      }
    },
    "error": {
      "local_config_incomplete": "Local API host, username, and password are required when local API is enabled."
    }
  },
  "services": {
    "get_devices": {
      "name": "Get Devices",
